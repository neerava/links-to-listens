# ollama_model: gpt-oss:20b
# ollama_model: llama3
ollama_model: llama3.1:8b
ollama_url: http://localhost:11434
# System prompt for turning article text into a TTS-ready podcast script.
# The article is appended after "---" when sent to the model.
ollama_prompt: |
  You are a podcast host. Convert the following article into a natural, conversational
  audio script suitable for text-to-speech.

  Coverage:
  - Cover ALL points, facts, arguments, and examples from the article. Do not skip or
    summarize away any section. Every distinct idea in the article must appear in the script.
  - Preserve important quotes, statistics, and specific details verbatim.
  - If the article has multiple sections or arguments, address each one in order.

  Style:
  - Begin with the content immediately, do not start with generic intros like,
    “Here’s the script” or “Welcome to the show” or sign offs
  - No bullet points, headers, or markdown.
  - Add small pauses, filler phrases with a bit of humor and personality
  - Write as if speaking directly to a listener.

  Structure:
  - Smooth storytelling flow (no rigid sections)
  - End with a reflective or interesting closing thought
  

tts_engine: vibevoice
tts_voice: default

# Path to a reference voice WAV file (24kHz mono recommended).
# The model clones this voice for synthesis — better audio quality with a real sample.
# Leave empty to use a silent fallback (lower quality).
# Example: tts_voice_sample: ./voices/speaker.wav
tts_voice_sample: ./voices/speaker3.wav

# Higher-fidelity TTS options (more = better quality, slower / larger files)
tts_ddpm_steps: 15        # diffusion steps (1–50); default 15, try 20 for best quality
tts_cfg_scale: 1.3        # voice guidance strength (1.0–2.0); 1.4–1.5 can improve clarity
tts_mp3_bitrate: 192      # 128 | 192 | 256 | 320 kbps; 256 or 320 for higher fidelity
tts_use_float32: true    # true = float32 on GPU/MPS (better quality, ~2x memory; may OOM)

scrape_timeout_sec: 20
output_dir: ./output
web_port: 8080
script_api_port: 8081
audio_api_port: 8082
poll_interval_sec: 5
max_input_tokens: 4096

# Number of sentences processed per TTS inference call.
# Lower values use less peak device memory; higher values may sound more natural.
# Reduce to 5 if you still hit OOM.
# Must be greater than 0.
tts_chunk_sentences: 50

# Days to retain intermediate pipeline files (script.txt, tts_input.txt).
# After this period they are auto-deleted by the watcher (once per day).
# The final MP3 and state.json are never auto-deleted.
intermediate_retention_days: 3

# Podbean publishing (optional — leave empty to disable)
# Get App ID and App Secret from https://developers.podbean.com/
# podbean_client_id: ""
# podbean_client_secret: ""

# Telegram bot (optional — send URLs via chat to queue them)
# Get a token from @BotFather on Telegram
# telegram_bot_token: ""
# telegram_allowed_user_ids: ""    # comma-separated Telegram user IDs; empty = allow all
# telegram_poll_interval_sec: 30
